# ==========================================
# UV & Virtual Environments
# ==========================================
# Always ignore uv's auto-managed or local virtual environment
.venv/

# DO NOT ignore uv.lock for applications! 
# (It ensures reproducible builds across teams and CI/CD).
# If you are explicitly building a library meant for PyPI, 
# you may optionally choose to uncomment the line below:
# uv.lock

# ==========================================
# Python Artifacts & Caching
# ==========================================
__pycache__/
*.py[cod]
*$py.class

# ==========================================
# Distribution, Building, & Packaging
# ==========================================
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ==========================================
# Environment Variables & Secrets
# ==========================================
.env
.env.local
.env.*
.secrets

# ==========================================
# IDEs & System Files
# ==========================================
.vscode/
.idea/
.DS_Store
Thumbs.db
